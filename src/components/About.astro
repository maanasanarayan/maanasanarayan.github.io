---
import { GraduationCap, Wrench } from 'lucide-react';
import SectionHeader from './SectionHeader.astro';

interface Education {
  period: string;
  degree: string;
  school: string;
  extra?: string;
}
interface About {
  skills: Record<string, string>;
  education: Education[];
}
const { about } = Astro.props as { about: About };
const skillEntries = Object.entries(about.skills);
const CARD_COLORS = [
  'bg-neo-secondary',
  'bg-neo-muted',
  'bg-neo-mint',
  'bg-neo-accent',
  'bg-neo-sky',
  'bg-white',
];
---

<div>
  <SectionHeader kicker="01 · About me" title="About & Skills." />

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      skillEntries.map(([category, items], idx) => {
        const tilt =
          idx % 3 === 1
            ? 'rotate-[-0.4deg]'
            : idx % 3 === 2
              ? 'rotate-[0.5deg]'
              : '';
        return (
          <div
            class={[
              'group border-4 border-black p-6 shadow-[8px_8px_0_0_#000]',
              'transition-all duration-200 hover:-translate-y-1 hover:shadow-[12px_12px_0_0_#000]',
              CARD_COLORS[idx % CARD_COLORS.length],
              tilt,
            ].join(' ')}
          >
            <div class="mb-3 flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center border-2 border-black bg-white">
                <Wrench className="h-4 w-4 stroke-[3px]" />
              </span>
              <h3 class="font-display text-xl tracking-tight uppercase">
                {category}
              </h3>
            </div>
            <p class="text-base leading-snug font-medium">{items}</p>
          </div>
        );
      })
    }
  </div>

  <div class="mt-14">
    <div class="mb-6 flex items-center gap-3">
      <span
        class="bg-neo-accent grid h-12 w-12 place-items-center border-4 border-black shadow-[4px_4px_0_0_#000]"
      >
        <GraduationCap className="h-6 w-6 stroke-[3px] text-white" />
      </span>
      <h3 class="font-display text-3xl tracking-tight uppercase sm:text-4xl">
        Education
      </h3>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        about.education.map((edu) => (
          <div class="border-4 border-black bg-white shadow-[8px_8px_0_0_#000] transition-all duration-200 hover:-translate-y-1 hover:shadow-[12px_12px_0_0_#000]">
            <div class="bg-neo-secondary flex items-center justify-between gap-3 border-b-4 border-black px-5 py-3">
              <span class="font-display text-lg tracking-tight uppercase sm:text-xl">
                {edu.degree}
              </span>
              <span class="shrink-0 border-2 border-black bg-white px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase sm:text-xs">
                {edu.period}
              </span>
            </div>
            <div class="p-5">
              <p class="text-lg font-bold tracking-tight uppercase">
                {edu.school}
              </p>
              {edu.extra && (
                <p class="mt-1 text-sm font-medium opacity-80">{edu.extra}</p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
