---
import SectionHeader from './SectionHeader.astro';
import ContactCard from './react/ContactCard.jsx';

interface ContactData {
  email: string;
  phone: string;
  linkedin: string;
  github: string;
}
const { contact } = Astro.props as { contact: ContactData };
---

<div>
  <SectionHeader kicker="05 · Say hello" title="Contact." />
  <ContactCard contact={contact} client:load />
</div>
