---
import { MapPin, Calendar, Briefcase } from 'lucide-astro';
import SectionHeader from './SectionHeader.astro';

interface ExpItem {
  company: string;
  logo: string;
  role: string;
  location: string;
  period: string;
  bullets: string[];
}
const { experiences } = Astro.props as { experiences: ExpItem[] };
const ALT_COLORS = [
  'bg-neo-secondary',
  'bg-neo-muted',
  'bg-neo-mint',
  'bg-neo-accent',
  'bg-neo-sky',
];
---

<div>
  <SectionHeader kicker="02 · Where I’ve shipped" title="Work Experience." />

  <ol class="space-y-8">
    {
      experiences.map((exp, idx) => (
        <li class="border-4 border-black bg-white shadow-[10px_10px_0_0_#000] transition-all duration-200 hover:-translate-y-1 hover:shadow-[14px_14px_0_0_#000]">
          <div
            class={`flex flex-col justify-between gap-4 border-b-4 border-black ${ALT_COLORS[idx % ALT_COLORS.length]} px-5 py-4 sm:flex-row sm:items-center sm:px-6`}
          >
            <div class="flex items-center gap-4">
              <span class="grid h-14 w-14 shrink-0 place-items-center border-4 border-black bg-white shadow-[3px_3px_0_0_#000]">
                <img
                  src={exp.logo}
                  alt={`${exp.company} logo`}
                  width="36"
                  height="36"
                  loading="lazy"
                  decoding="async"
                  class="h-9 w-9 object-contain"
                />
              </span>
              <div>
                <h3 class="font-display text-xl tracking-tight uppercase sm:text-2xl">
                  {exp.role}
                </h3>
                <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-bold tracking-widest uppercase">
                  <span class="inline-flex items-center gap-1.5">
                    <Briefcase class="h-3.5 w-3.5 stroke-[3px]" />
                    {exp.company}
                  </span>
                  <span aria-hidden>•</span>
                  <span class="inline-flex items-center gap-1.5">
                    <MapPin class="h-3.5 w-3.5 stroke-[3px]" />
                    {exp.location}
                  </span>
                </div>
              </div>
            </div>

            <span class="inline-flex items-center gap-1.5 self-start border-2 border-black bg-white px-2.5 py-1 text-[11px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#000] sm:self-auto">
              <Calendar class="h-3.5 w-3.5 stroke-[3px]" />
              {exp.period}
            </span>
          </div>

          <ul class="list-none space-y-3 p-5 sm:p-6">
            {exp.bullets.map((bullet) => (
              <li class="flex gap-3 leading-snug">
                <span
                  aria-hidden
                  class="bg-neo-accent mt-2 h-3 w-3 shrink-0 border-2 border-black"
                />
                <span class="text-base font-medium sm:text-lg">{bullet}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</div>
