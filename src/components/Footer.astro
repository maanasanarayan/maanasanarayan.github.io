---
import content from '../data/content.js';

interface Props {
  name: string;
}
const { name } = Astro.props;
const year = new Date().getFullYear();
const { email, linkedin, github, twitter } = content.contact;
---

<footer class="no-print bg-neo-secondary border-t-4 border-black">
  <div
    class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 py-8 sm:flex-row sm:px-6 lg:px-10"
  >
    <p class="text-sm font-bold tracking-widest uppercase">
      © {year}{' '}
      {name}. All rights reserved.
    </p>
    <nav
      aria-label="Author links"
      class="flex flex-wrap items-center gap-2 text-xs font-bold tracking-widest uppercase"
    >
      <a
        href={`mailto:${email}`}
        class="hover:bg-neo-mint border-2 border-black bg-white px-2.5 py-1 shadow-[2px_2px_0_0_#000] transition-all duration-100 hover:-translate-y-0.5"
        >Email</a
      >
      <a
        href={linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:bg-neo-mint border-2 border-black bg-white px-2.5 py-1 shadow-[2px_2px_0_0_#000] transition-all duration-100 hover:-translate-y-0.5"
        >LinkedIn</a
      >
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:bg-neo-mint border-2 border-black bg-white px-2.5 py-1 shadow-[2px_2px_0_0_#000] transition-all duration-100 hover:-translate-y-0.5"
        >GitHub</a
      >
      <a
        href={twitter}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:bg-neo-mint border-2 border-black bg-white px-2.5 py-1 shadow-[2px_2px_0_0_#000] transition-all duration-100 hover:-translate-y-0.5"
        >X</a
      >
    </nav>
  </div>
</footer>
