---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import NavBar from '../components/react/NavBar.jsx';
import Footer from '../components/Footer.astro';
import content from '../data/content.js';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string | Date;
  /** When true, navbar links scroll to in-page sections (#about, etc). */
  isHome?: boolean;
}

const {
  title = 'Maanasa Narayan — Software Engineer Portfolio',
  description = 'Maanasa Narayan is a software engineer in the Bay Area, CA building scalable web applications and backend cloud systems. Engineering experience across Kayak, Amazon, Nokia, and Adobe.',
  image = '/images/maanasan.jpg',
  type = 'website',
  publishedTime,
  isHome = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Maanasa Narayan" />
    <meta
      name="keywords"
      content="Maanasa Narayan, software engineer, full stack developer, Bay Area, React, Java, AWS, portfolio, Kayak, Amazon, Adobe, Nokia"
    />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />

    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#FFD93D" />
    <meta name="color-scheme" content="light" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Maanasa Narayan" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta
      property="og:image:alt"
      content="Portrait of Maanasa Narayan, Software Engineer"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    {
      publishedTime && (
        <meta
          property="article:published_time"
          content={new Date(publishedTime).toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="Portrait of Maanasa Narayan, Software Engineer"
    />

    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-archivo-black" preload />
    <Font cssVariable="--font-jetbrains-mono" />

    <!-- Structured Data: Person -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Maanasa Narayan',
        url: 'https://maanasa.dev/',
        image: 'https://maanasa.dev/images/maanasan.jpg',
        jobTitle: 'Software Engineer',
        description:
          'Software Engineer focused on building scalable web applications and backend cloud systems.',
        email: 'mailto:mnsnryn@gmail.com',
        telephone: '+1-774-777-8729',
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Bay Area',
          addressRegion: 'CA',
          addressCountry: 'US',
        },
        sameAs: [
          'https://www.linkedin.com/in/maanasa-narayan/',
          'https://github.com/maanasanarayan',
        ],
        alumniOf: [
          {
            '@type': 'CollegeOrUniversity',
            name: 'Northeastern University',
            sameAs: 'https://www.northeastern.edu/',
          },
          { '@type': 'CollegeOrUniversity', name: 'KSIT, VTU' },
        ],
        worksFor: {
          '@type': 'Organization',
          name: 'Kayak',
          sameAs: 'https://www.kayak.com/',
        },
        knowsAbout: [
          'Software Engineering',
          'Java',
          'Python',
          'JavaScript',
          'TypeScript',
          'React',
          'Node.js',
          'AWS',
          'Cloud Infrastructure',
          'RESTful APIs',
          'Backend Systems',
          'CI/CD',
        ],
      })}
    />
    <slot name="head" />
    <ClientRouter />
  </head>

  <body>
    <NavBar
      name={content.profile.name}
      isHome={isHome}
      currentPath={Astro.url.pathname}
      client:load
    />

    <slot />

    <Footer name={content.profile.name} />
  </body>
</html>
