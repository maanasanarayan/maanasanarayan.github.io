---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { Filter, ArrowUpRight, Palette } from 'lucide-react';

const pieces = (await getCollection('gallery', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const categories = Array.from(new Set(pieces.map((p) => p.data.category)));

const aspectClasses: Record<string, string> = {
  portrait: 'aspect-[4/5]',
  landscape: 'aspect-[4/3]',
  square: 'aspect-square',
};

const tileBg = [
  'bg-neo-secondary',
  'bg-neo-muted',
  'bg-neo-mint',
  'bg-neo-sky',
  'bg-neo-accent',
];

const categoryLabel: Record<string, string> = {
  ceramics: 'Ceramics',
  textiles: 'Textiles',
  prints: 'Prints',
  paper: 'Paper',
  'mixed-media': 'Mixed media',
  'home-decor': 'Home decor',
};
---

<BaseLayout
  title="Lifestyle — Maanasa Narayan"
  description="A gallery of ceramics, textiles, prints, and home-decor pieces — handmade, with notes on the inspiration behind each one."
>
  <main
    class="mx-auto max-w-7xl px-4 pt-24 pb-20 sm:px-6 sm:pt-32 sm:pb-24 lg:px-10"
  >
    <SectionHeader kicker="Pen · brush · paper" title="Lifestyle." as="h1" />

    <p
      class="mb-8 max-w-2xl text-lg leading-snug font-medium sm:text-xl lg:text-2xl"
    >
      A sketchbook in public — small doodle practice from the margins of
      ordinary days. Each piece has a note on the moment that prompted it. Live
      versions live at
      <a
        href="https://www.instagram.com/doodles.by.maanasa/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-neo-secondary hover:bg-neo-mint inline-block border-b-4 border-black px-1 font-bold"
        >@doodles.by.maanasa</a
      >.
    </p>

    <!-- Category filter -->
    <div class="mb-12 flex flex-wrap items-center gap-2">
      <span
        class="text-neo-bg inline-flex items-center gap-2 border-4 border-black bg-black px-3 py-1 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#FFD93D]"
      >
        <Filter className="h-3.5 w-3.5 stroke-[3px]" />
        Filter
      </span>
      <button
        type="button"
        data-cat-filter="*"
        data-active="true"
        class="hover:bg-neo-mint inline-flex items-center gap-1 border-2 border-black bg-white px-2.5 py-1 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#000] data-[active=true]:bg-black data-[active=true]:text-white"
      >
        All ({pieces.length})
      </button>
      {
        categories.map((cat) => {
          const count = pieces.filter((p) => p.data.category === cat).length;
          return (
            <button
              type="button"
              data-cat-filter={cat}
              class="hover:bg-neo-mint inline-flex items-center gap-1 border-2 border-black bg-white px-2.5 py-1 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#000] data-[active=true]:bg-black data-[active=true]:text-white"
            >
              {categoryLabel[cat] ?? cat} ({count})
            </button>
          );
        })
      }
    </div>

    <!-- Masonry-ish gallery using CSS columns -->
    <ul id="gallery" class="columns-1 gap-6 sm:columns-2 lg:columns-3">
      {
        pieces.map((piece, idx) => {
          const tilt =
            idx % 3 === 0
              ? 'rotate-[-0.6deg]'
              : idx % 3 === 1
                ? 'rotate-[0.5deg]'
                : 'rotate-[-0.2deg]';
          return (
            <li
              class={['gallery-card mb-6 break-inside-avoid', tilt].join(' ')}
              data-category={piece.data.category}
            >
              <a
                href={`/lifestyle/${piece.id}/`}
                class={[
                  'group block border-4 border-black bg-white shadow-[8px_8px_0_0_#000]',
                  'transition-all duration-200 hover:-translate-y-1.5 hover:shadow-[14px_14px_0_0_#000]',
                ].join(' ')}
              >
                <div
                  class={[
                    'relative w-full overflow-hidden border-b-4 border-black',
                    aspectClasses[piece.data.aspect],
                  ].join(' ')}
                >
                  <img
                    src={piece.data.image}
                    alt={piece.data.imageAlt}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  />
                  <span
                    class={[
                      'absolute top-3 left-3 inline-flex items-center gap-1 border-2 border-black px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#000]',
                      tileBg[idx % tileBg.length],
                    ].join(' ')}
                  >
                    {categoryLabel[piece.data.category] ?? piece.data.category}
                  </span>
                </div>

                <div class="p-5">
                  <h2 class="font-display text-xl leading-tight tracking-tight uppercase sm:text-2xl">
                    {piece.data.title}
                  </h2>
                  <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-[11px] font-bold tracking-widest uppercase">
                    <span>{piece.data.medium}</span>
                    <span aria-hidden>·</span>
                    <span>{piece.data.year}</span>
                  </div>
                  <div class="mt-4 flex items-center justify-between gap-3">
                    <div class="flex items-center gap-1.5">
                      <Palette className="h-3.5 w-3.5 stroke-[3px]" />
                      <div class="flex items-center gap-1">
                        {piece.data.palette.slice(0, 5).map((c) => (
                          <span
                            class="block h-4 w-4 border-2 border-black"
                            style={`background:${c}`}
                            aria-hidden
                          />
                        ))}
                      </div>
                    </div>
                    <span class="inline-flex items-center gap-1 text-xs font-bold tracking-widest uppercase">
                      View
                      <ArrowUpRight className="h-4 w-4 stroke-[3px] transition-transform duration-200 group-hover:rotate-12" />
                    </span>
                  </div>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>

    <p
      id="gallery-empty"
      class="mt-8 hidden border-4 border-black bg-white p-6 text-base font-bold shadow-[6px_6px_0_0_#000]"
    >
      No pieces in this category yet.
    </p>
  </main>

  <script is:inline data-astro-rerun>
    function initGallery() {
      const cards = Array.from(document.querySelectorAll('.gallery-card'));
      const buttons = Array.from(
        document.querySelectorAll('[data-cat-filter]'),
      );
      if (!buttons.length) return;
      const empty = document.getElementById('gallery-empty');

      function apply(active) {
        let visible = 0;
        for (const c of cards) {
          const cat = c.getAttribute('data-category') || '';
          const show = active === '*' || cat === active;
          c.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        if (empty) empty.classList.toggle('hidden', visible !== 0);
      }

      for (const b of buttons) {
        b.addEventListener('click', () => {
          const v = b.getAttribute('data-cat-filter') || '*';
          for (const x of buttons) {
            x.setAttribute('data-active', x === b ? 'true' : 'false');
          }
          apply(v);
        });
      }
    }

    initGallery();
    document.addEventListener('astro:page-load', initGallery);
  </script>
</BaseLayout>
