---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { ArrowLeft, ArrowUpRight, Calendar, Tag } from 'lucide-react';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Set<string>();
  for (const p of posts) for (const t of p.data.tags) tags.add(t);
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

const CARD_BG = [
  'bg-neo-secondary',
  'bg-neo-muted',
  'bg-neo-mint',
  'bg-neo-sky',
  'bg-neo-accent',
];

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`#${tag} — Maanasa Narayan`}
  description={`Blog posts tagged with ${tag}.`}
>
  <main
    class="mx-auto max-w-7xl px-4 pt-24 pb-20 sm:px-6 sm:pt-32 sm:pb-24 lg:px-10"
  >
    <div class="mb-8 flex flex-wrap gap-3">
      <a
        href="/blog"
        class="hover:bg-neo-secondary inline-flex items-center gap-2 border-4 border-black bg-white px-4 py-2 text-xs font-bold tracking-widest uppercase shadow-[4px_4px_0_0_#000] transition-all duration-100 hover:-translate-y-0.5"
      >
        <ArrowLeft className="h-4 w-4 stroke-[3px]" />
        All posts
      </a>
      <a
        href="/blog/tags/"
        class="hover:bg-neo-secondary inline-flex items-center gap-2 border-4 border-black bg-white px-4 py-2 text-xs font-bold tracking-widest uppercase shadow-[4px_4px_0_0_#000] transition-all duration-100 hover:-translate-y-0.5"
      >
        <Tag className="h-4 w-4 stroke-[3px]" />
        All tags
      </a>
    </div>

    <SectionHeader
      kicker={`#${tag}`}
      title={`Posts tagged "${tag}".`}
      as="h1"
    />

    <ul class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        posts.map((post, idx) => {
          const tilt =
            idx % 2 === 0 ? 'md:rotate-[-0.4deg]' : 'md:rotate-[0.4deg]';
          return (
            <li
              class={[
                'group relative',
                'transition-all duration-200 hover:-translate-y-1.5',
                tilt,
              ].join(' ')}
            >
              <a
                href={`/blog/${post.id}/`}
                class="block border-4 border-black bg-white shadow-[10px_10px_0_0_#000] transition-all duration-200 group-hover:shadow-[14px_14px_0_0_#000]"
              >
                <div
                  class={`relative border-b-4 border-black ${CARD_BG[idx % CARD_BG.length]} px-5 py-4`}
                >
                  {post.data.heroEmoji && (
                    <span
                      aria-hidden
                      class="absolute -top-5 -right-4 grid h-12 w-12 rotate-12 place-items-center border-4 border-black bg-white text-2xl shadow-[3px_3px_0_0_#000]"
                    >
                      {post.data.heroEmoji}
                    </span>
                  )}
                  <div class="flex items-center gap-2 text-[11px] font-bold tracking-widest uppercase">
                    <Calendar className="h-3.5 w-3.5 stroke-[3px]" />
                    <time datetime={post.data.pubDate.toISOString()}>
                      {fmtDate(post.data.pubDate)}
                    </time>
                  </div>
                  <h2 class="font-display mt-2 pr-12 text-2xl leading-tight tracking-tight uppercase sm:text-3xl">
                    {post.data.title}
                  </h2>
                </div>
                <div class="p-5">
                  <p class="text-base leading-snug font-medium">
                    {post.data.description}
                  </p>
                  <div class="mt-5 flex items-center justify-end">
                    <span class="inline-flex items-center gap-1 text-xs font-bold tracking-widest uppercase">
                      Read
                      <ArrowUpRight className="h-4 w-4 stroke-[3px] transition-transform duration-200 group-hover:rotate-12" />
                    </span>
                  </div>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </main>
</BaseLayout>
