---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { ArrowUpRight, Calendar, Tag } from 'lucide-react';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const CARD_BG = [
  'bg-neo-secondary',
  'bg-neo-muted',
  'bg-neo-mint',
  'bg-neo-sky',
  'bg-neo-accent',
];

const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const tags = Array.from(tagCounts.entries()).sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog — Maanasa Narayan"
  description="Notes on software engineering, design, and shipping things — from Maanasa Narayan."
>
  <Fragment slot="head">
    <link
      rel="stylesheet"
      href="/pagefind/pagefind-ui.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    </noscript>
  </Fragment>

  <main
    class="mx-auto max-w-7xl px-4 pt-24 pb-20 sm:px-6 sm:pt-32 sm:pb-24 lg:px-10"
  >
    <SectionHeader kicker="Notes from the field" title="Blog." as="h1" />

    <p
      class="mb-8 max-w-2xl text-lg leading-snug font-medium sm:text-xl lg:text-2xl"
    >
      Short posts on shipping software, frontend design, and the occasional
      postmortem. Subscribe via <a
        href="/rss.xml"
        class="bg-neo-mint hover:bg-neo-secondary inline-block border-b-4 border-black px-1 font-bold"
        >RSS</a
      >.
    </p>

    {
      tags.length > 0 && (
        <div class="mb-8 flex flex-wrap items-center gap-2">
          <span class="text-neo-bg inline-flex items-center gap-2 border-4 border-black bg-black px-3 py-1 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#FFD93D]">
            <Tag className="h-3.5 w-3.5 stroke-[3px]" />
            Filter
          </span>
          <button
            type="button"
            data-tag-filter="*"
            data-active="true"
            class="hover:bg-neo-mint inline-flex items-center gap-1 border-2 border-black bg-white px-2.5 py-1 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#000] data-[active=true]:bg-black data-[active=true]:text-white"
          >
            All ({posts.length})
          </button>
          {tags.map(([tag, count]) => (
            <button
              type="button"
              data-tag-filter={tag}
              class="hover:bg-neo-mint inline-flex items-center gap-1 border-2 border-black bg-white px-2.5 py-1 text-[10px] font-bold tracking-widest uppercase shadow-[3px_3px_0_0_#000] data-[active=true]:bg-black data-[active=true]:text-white"
            >
              {tag} ({count})
            </button>
          ))}
        </div>
      )
    }

    <div
      id="search"
      data-search-shell
      hidden
      class="mb-10 border-4 border-black bg-white p-5 shadow-[8px_8px_0_0_#000]"
    >
    </div>

    <p
      id="blog-empty"
      hidden
      class="mb-8 border-4 border-black bg-white p-6 text-base font-bold shadow-[6px_6px_0_0_#000]"
    >
      No posts in this tag.
    </p>

    <ul class="grid grid-cols-1 gap-8 md:grid-cols-2" data-blog-list>
      {
        posts.map((post, idx) => {
          const tilt =
            idx % 2 === 0 ? 'md:rotate-[-0.4deg]' : 'md:rotate-[0.4deg]';
          return (
            <li
              class={[
                'group blog-card relative',
                'transition-all duration-200 hover:-translate-y-1.5',
                tilt,
              ].join(' ')}
              data-tags={post.data.tags.join(' ').toLowerCase()}
            >
              <a
                href={`/blog/${post.id}/`}
                class="block border-4 border-black bg-white shadow-[10px_10px_0_0_#000] transition-all duration-200 group-hover:shadow-[14px_14px_0_0_#000]"
              >
                <div
                  class={`relative border-b-4 border-black ${CARD_BG[idx % CARD_BG.length]} px-5 py-4`}
                >
                  {post.data.heroEmoji && (
                    <span
                      aria-hidden
                      class="absolute -top-5 -right-4 grid h-12 w-12 rotate-12 place-items-center border-4 border-black bg-white text-2xl shadow-[3px_3px_0_0_#000]"
                    >
                      {post.data.heroEmoji}
                    </span>
                  )}
                  <div class="flex items-center gap-2 text-[11px] font-bold tracking-widest uppercase">
                    <Calendar className="h-3.5 w-3.5 stroke-[3px]" />
                    <time datetime={post.data.pubDate.toISOString()}>
                      {fmtDate(post.data.pubDate)}
                    </time>
                  </div>
                  <h2 class="font-display mt-2 pr-12 text-2xl leading-tight tracking-tight uppercase sm:text-3xl">
                    {post.data.title}
                  </h2>
                </div>

                <div class="p-5">
                  <p class="text-base leading-snug font-medium">
                    {post.data.description}
                  </p>
                  <div class="mt-5 flex flex-wrap items-center justify-between gap-3">
                    <div class="flex flex-wrap items-center gap-2">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="bg-neo-bg inline-flex items-center gap-1 border-2 border-black px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase">
                          <Tag className="h-3 w-3 stroke-[3px]" />
                          {tag}
                        </span>
                      ))}
                    </div>
                    <span class="inline-flex items-center gap-1 text-xs font-bold tracking-widest uppercase">
                      Read
                      <ArrowUpRight className="h-4 w-4 stroke-[3px] transition-transform duration-200 group-hover:rotate-12" />
                    </span>
                  </div>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </main>

  <script is:inline src="/pagefind/pagefind-ui.js" defer></script>
  <script is:inline>
    (function () {
      const list = document.querySelector('[data-blog-list]');
      const cards = Array.from(document.querySelectorAll('.blog-card'));
      const empty = document.getElementById('blog-empty');
      const buttons = Array.from(
        document.querySelectorAll('[data-tag-filter]'),
      );

      function applyTag(active) {
        let visible = 0;
        for (const c of cards) {
          const tags = (c.getAttribute('data-tags') || '').split(/\s+/);
          const show = active === '*' || tags.includes(active);
          c.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        if (empty) empty.hidden = visible !== 0;
      }

      function selectTag(tag) {
        for (const b of buttons) {
          const isMatch = (b.getAttribute('data-tag-filter') || '*') === tag;
          b.setAttribute('data-active', isMatch ? 'true' : 'false');
        }
        applyTag(tag);
      }

      for (const b of buttons) {
        b.addEventListener('click', () => {
          const v = b.getAttribute('data-tag-filter') || '*';
          selectTag(v);
          const url = new URL(window.location.href);
          if (v === '*') url.searchParams.delete('tag');
          else url.searchParams.set('tag', v);
          history.replaceState(null, '', url);
        });
      }

      const initialTag = new URLSearchParams(window.location.search).get('tag');
      if (initialTag) selectTag(initialTag);

      window.addEventListener('DOMContentLoaded', () => {
        if (typeof window.PagefindUI !== 'function') return;
        const shell = document.querySelector('[data-search-shell]');
        if (shell) shell.hidden = false;
        new window.PagefindUI({
          element: '#search',
          showImages: false,
          showEmptyFilters: false,
          resetStyles: false,
          processTerm: (term) => {
            if (list) list.style.display = term ? 'none' : '';
            return term;
          },
        });
        document.querySelector('#search')?.addEventListener('click', (e) => {
          if (
            e.target.classList.contains('pagefind-ui__search-clear') &&
            list
          ) {
            list.style.display = '';
          }
        });
      });
    })();
  </script>
</BaseLayout>
