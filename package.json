{
  "name": "maanasa-portfolio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://maanasa.dev",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist/client",
    "preview": "bun run build && wrangler dev",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint . && markdownlint-cli2 \"**/*.{md,mdx}\" \"#node_modules\" \"#dist\" \"#.astro\"",
    "lint:fix": "eslint . --fix && markdownlint-cli2 --fix \"**/*.{md,mdx}\" \"#node_modules\" \"#dist\" \"#.astro\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "generate-types": "wrangler types",
    "deploy": "bun run build && wrangler deploy",
    "import:instagram": "node scripts/import-instagram.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ],
    "*.{json,css,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/markdoc": "^2.0.0",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "lucide-astro": "^0.556.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9",
    "@pagefind/default-ui": "^1.5.2",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9",
    "eslint-plugin-astro": "^2.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.22.1",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "reading-time": "^1.5.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "wrangler": "^4.104.0"
  },
  "overrides": {
    "vite": "^8.0.13"
  }
}
